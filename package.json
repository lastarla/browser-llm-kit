{
  "name": "browser-llm-kit",
  "private": false,
  "description": "Browser-side LLM toolkit with OPFS + Worker architecture and example hosts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lastarla/browser-llm-kit.git"
  },
  "homepage": "https://github.com/lastarla/browser-llm-kit",
  "bugs": {
    "url": "https://github.com/lastarla/browser-llm-kit/issues"
  },
  "keywords": [
    "browser-llm",
    "opfs",
    "web-llm",
    "worker",
    "mediapipe",
    "local-llm"
  ],
  "files": [
    "packages/",
    "examples/",
    "docs/",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "type": "module",
  "scripts": {
    "start": "node examples/meeting-notes-demo/server/index.js",
    "start:https": "PORT=3443 HTTPS_KEY_FILE=.local/certs/gemma4-preview-key.pem HTTPS_CERT_FILE=.local/certs/gemma4-preview.pem node examples/meeting-notes-demo/server/index.js",
    "build": "webpack --config webpack.config.cjs",
    "test": "node --test test/*.test.js",
    "verify": "npm test && npm run build",
    "benchmark:task-integrity": "node scripts/benchmark-task-integrity.mjs"
  },
  "dependencies": {
    "@mediapipe/tasks-genai": "^0.10.27"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^13.0.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  }
}
